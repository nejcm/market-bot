# Provider: openai | openai-compatible | codex | anthropic
MARKET_BOT_PROVIDER=openai

# For MARKET_BOT_PROVIDER=openai, set either key.
# For MARKET_BOT_PROVIDER=openai-compatible, only MARKET_BOT_OPENAI_API_KEY is used.
# For MARKET_BOT_PROVIDER=codex, no API key is needed; run `codex login`.
# For MARKET_BOT_PROVIDER=anthropic, set either Anthropic key.
OPENAI_API_KEY=
MARKET_BOT_OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MARKET_BOT_ANTHROPIC_API_KEY=

# Required only for MARKET_BOT_PROVIDER=openai-compatible.
# Must be https unless it targets localhost. Do not include credentials.
MARKET_BOT_BASE_URL=

MARKET_BOT_QUICK_MODEL=gpt-5.4-mini
MARKET_BOT_SYNTHESIS_MODEL=gpt-5.5
MARKET_BOT_REASONING_EFFORT=

# Optional Codex-only model overrides.
MARKET_BOT_CODEX_QUICK_MODEL=
MARKET_BOT_CODEX_SYNTHESIS_MODEL=

MARKET_BOT_MODEL_TIMEOUT_MS=120000
MARKET_BOT_DATA_DIR=data/runs

MARKET_BOT_EQUITY_MOVER_LIMIT=5
MARKET_BOT_CRYPTO_MOVER_LIMIT=5
MARKET_BOT_NEWS_LIMIT=8
MARKET_BOT_SOURCE_TIMEOUT_MS=15000

# Optional news provider tokens.
MARKET_BOT_MARKETAUX_API_TOKEN=
MARKET_BOT_FINNHUB_API_TOKEN=

# Optional ticker Extended Evidence providers.
MARKET_BOT_FRED_API_KEY=
MARKET_BOT_TRADIER_API_TOKEN=
MARKET_BOT_GLASSNODE_API_KEY=
MARKET_BOT_SEC_USER_AGENT=

# Optional supplemental equity source provider. Massive was formerly Polygon.io.
MARKET_BOT_MASSIVE_API_KEY=
# Legacy alias accepted for existing local env files.
MARKET_BOT_POLYGON_API_KEY=

MARKET_BOT_CACHE_DIR=data/cache
MARKET_BOT_CACHE_DISABLE=false
MARKET_BOT_CACHE_FALLBACK_DAYS=7

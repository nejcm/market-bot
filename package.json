{
  "name": "market-bot",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "market-bot": "./src/cli.ts"
  },
  "type": "module",
  "scripts": {
    "app": "bun run app/server.ts",
    "app:build": "vite build --config app/vite.config.ts",
    "app:dev": "bun run app/server.ts",
    "test": "bun test",
    "test:coverage": "bun run scripts/check-coverage.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:staged": "oxlint --fix",
    "fmt": "oxfmt src tests scripts app/*.ts app/client",
    "fmt:staged": "oxfmt",
    "fmt:check": "oxfmt --check src tests scripts app/*.ts app/client",
    "commitlint": "commitlint",
    "knip": "knip",
    "audit": "bun audit --audit-level=high",
    "check": "bun run lint && bun run fmt:check && bun run typecheck && bun test"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@lucide/svelte": "^1.17.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "1.3.14",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "knip": "6.14.1",
    "layerchart": "2.0.0-next.48",
    "lefthook": "2.1.8",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "shadcn-svelte": "^1.3.0",
    "svelte": "^5.56.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vite": "^8.0.16"
  }
}

{
  "name": "market-bot",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "market-bot": "./src/cli.ts"
  },
  "type": "module",
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun run scripts/check-coverage.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:staged": "oxlint --fix",
    "fmt": "oxfmt src tests scripts",
    "fmt:staged": "oxfmt",
    "fmt:check": "oxfmt --check src tests scripts",
    "commitlint": "commitlint",
    "knip": "knip",
    "audit": "bun audit --audit-level=high",
    "check": "bun run lint && bun run fmt:check && bun run typecheck && bun test"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@types/bun": "1.3.14",
    "knip": "6.14.2",
    "lefthook": "2.1.9",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "typescript": "5.9.3"
  }
}

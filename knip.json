{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": ["scripts/**/*.ts", "tests/**/*.ts"],
  "project": ["src/**/*.ts", "scripts/**/*.ts", "app/**/*.ts", "app/client/**/*.{ts,svelte}"],
  "vite": {
    "config": ["app/vite.config.ts"],
    "entry": ["app/index.html"]
  },
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": ["ai", "bun-types", "shadcn-svelte", "tw-animate-css"]
}

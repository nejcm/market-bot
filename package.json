{
  "name": "market-bot",
  "version": "0.1.1",
  "description": "Research-only CLI for sourced market updates, ticker briefs, observable predictions, and calibration",
  "keywords": [
    "bun",
    "calibration",
    "cli",
    "finance",
    "market-research",
    "predictions"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nejcm/market-bot.git"
  },
  "bin": {
    "market-bot": "./src/cli.ts"
  },
  "type": "module",
  "scripts": {
    "app": "bun run app:build && bun run app:serve",
    "app:serve": "bun run app/server.ts",
    "app:dev": "bun run app/dev.ts",
    "app:build": "vite build --config app/vite.config.ts",
    "test": "bun test",
    "test:coverage": "bun run scripts/check-coverage.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:ts": "bun run typecheck",
    "lint:fix": "oxlint --fix",
    "lint:staged": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check src tests scripts app/*.ts app/client",
    "commitlint": "commitlint",
    "knip": "knip --production",
    "audit": "bun audit --audit-level=high",
    "check": "bun run fmt && bun run lint && bun run fmt:check && bun run typecheck && bun run test:coverage"
  },
  "devDependencies": {
    "@ai-sdk/svelte": "4.0.208",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@lucide/svelte": "1.17.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.3.0",
    "@types/bun": "1.3.14",
    "ai": "6.0.208",
    "bits-ui": "2.16.3",
    "clsx": "2.1.1",
    "dompurify": "3.4.11",
    "knip": "6.14.1",
    "lefthook": "2.1.8",
    "lightweight-charts": "5.2.0",
    "marked": "18.0.5",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "shadcn-svelte": "1.3.0",
    "svelte": "5.56.1",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "3.2.2",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "vite": "8.0.16"
  }
}

# Provider: openai | openai-compatible | codex | anthropic
MARKET_BOT_PROVIDER=openai

# For MARKET_BOT_PROVIDER=openai, set either key.
# For MARKET_BOT_PROVIDER=openai-compatible, only MARKET_BOT_OPENAI_API_KEY is used.
# For MARKET_BOT_PROVIDER=codex, no API key is needed; run `codex login`.
# For MARKET_BOT_PROVIDER=anthropic, set either Anthropic key.
OPENAI_API_KEY=
MARKET_BOT_OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MARKET_BOT_ANTHROPIC_API_KEY=

# Required only for MARKET_BOT_PROVIDER=openai-compatible.
# Must be https unless it targets localhost. Do not include credentials.
MARKET_BOT_BASE_URL=

MARKET_BOT_QUICK_MODEL=gpt-5.4-mini
MARKET_BOT_SYNTHESIS_MODEL=gpt-5.5
MARKET_BOT_REASONING_EFFORT=medium

# Optional Codex-only model overrides.
MARKET_BOT_CODEX_QUICK_MODEL=
MARKET_BOT_CODEX_SYNTHESIS_MODEL=
MARKET_BOT_FORECAST_DISAGREEMENT_MODELS=

MARKET_BOT_MODEL_TIMEOUT_MS=120000
MARKET_BOT_DATA_DIR=data/runs
MARKET_BOT_INDEX_DB_PATH=
MARKET_BOT_INDEX_DISABLE=false
MARKET_BOT_CONSOLE_PORT=4173
MARKET_BOT_PROMPT_DIR=

MARKET_BOT_EQUITY_MOVER_LIMIT=5
MARKET_BOT_CRYPTO_MOVER_LIMIT=5
MARKET_BOT_NEWS_LIMIT=8
MARKET_BOT_NEWS_SEEN_PATH=
MARKET_BOT_NEWS_SEEN_RETENTION_DAYS=30
MARKET_BOT_SOURCE_TIMEOUT_MS=15000

# ApeWisdom alpha-search.
MARKET_BOT_APEWISDOM_FILTER=all-stocks
MARKET_BOT_APEWISDOM_BRIEF_PAGE_LIMIT=5
MARKET_BOT_APEWISDOM_DEEP_PAGE_LIMIT=10
MARKET_BOT_ALPHA_SEARCH_VALIDATION_LIMIT=25
MARKET_BOT_ALPHA_SEARCH_LEAD_LIMIT=15
MARKET_BOT_ALPHA_SEARCH_CANDIDATE_LIMIT=15
MARKET_BOT_ALPHA_SEARCH_SEC_DISCOVERY_LIMIT=25
MARKET_BOT_ALPHA_SEARCH_SEC_FORM_TYPES=S-1,F-1,8-K,6-K
MARKET_BOT_ALPHA_SEARCH_MIN_PRICE=0.50
MARKET_BOT_ALPHA_SEARCH_MIN_VOLUME=100000
MARKET_BOT_ALPHA_SEARCH_MIN_MARKET_CAP=50000000
MARKET_BOT_ALPHA_SEARCH_MAX_MARKET_CAP=10000000000

MARKET_BOT_EVIDENCE_REQUEST_MAX_ROUNDS=2
MARKET_BOT_EVIDENCE_REQUEST_MAX_TOOL_CALLS=2
MARKET_BOT_EVIDENCE_REQUEST_SOURCE_BUDGET=8
MARKET_BOT_RESEARCH_GATHER_MAX_ROUNDS=4
MARKET_BOT_RESEARCH_GATHER_MAX_TOOL_CALLS=8
MARKET_BOT_RESEARCH_GATHER_SOURCE_BUDGET=24

MARKET_BOT_MARKET_SPOTLIGHT_BRIEF_LIMIT=2
MARKET_BOT_MARKET_SPOTLIGHT_DEEP_LIMIT=4
MARKET_BOT_MARKET_SPOTLIGHT_CANDIDATE_LIMIT=40

MARKET_BOT_HISTORY_TICKER_RECENT_LIMIT=3
MARKET_BOT_HISTORY_MARKET_RECENT_LIMIT=5
MARKET_BOT_HISTORY_RECENT_DAYS=90
MARKET_BOT_HISTORY_ANCHOR_MONTHS=3,6,12
MARKET_BOT_HISTORY_MISS_CORRECTION_LIMIT=2

# Optional news provider tokens.
MARKET_BOT_MARKETAUX_API_TOKEN=
MARKET_BOT_FINNHUB_API_TOKEN=

# Recommended free Extended Evidence providers.
# FRED keys are free and enable macro context/evidence/scoring.
MARKET_BOT_FRED_API_KEY=
# SEC EDGAR is free; replace with an app name and real contact email for live access.
MARKET_BOT_SEC_USER_AGENT=market-bot your-email@example.com

# Optional equity options/IV provider. Free/delayed access depends on Tradier account/API access.
MARKET_BOT_TRADIER_API_TOKEN=

# Optional crypto on-chain provider. Glassnode API access is paid/API-add-on; leave blank for free setups.
MARKET_BOT_GLASSNODE_API_KEY=

# Optional supplemental equity source provider. Massive was formerly Polygon.io.
MARKET_BOT_MASSIVE_API_KEY=
# Legacy alias accepted for existing local env files.
MARKET_BOT_POLYGON_API_KEY=

MARKET_BOT_CACHE_DIR=data/cache
MARKET_BOT_CACHE_DISABLE=false
MARKET_BOT_CACHE_FALLBACK_DAYS=7
